#
# Initialize percepts
#

['result'] = ['current'] = []

#
# Test Decision
#

['test'] = []
['test'] ~= {[sky]->[blue]}*{[time]->[day]}*{[weather]->[nice]}
['test'] ~= {[sky]->[black]}*{[time]->[night]}
['test'] ~= {[sky]->[grey]}*{[time]->[day]}*{[weather]->[bad]}
['test'] @ {[sky]->['current']}*{[time]->[day]}*{[weather]->[nice]}

['result'] = ^['current']
['result'] *= ![blue]

#
# Finalize result
#

['result'] ~= [success]
