#
# Just some random statements
#

['test'] ~= {[sun]->[shines]}*{[sky]->[blue]}
['test'] ~= {[sun]->[shines]}*{[sky]->[red]}

#
# Result should evaluate to [success], since [test]*![test] == []
#

[test]*[success]*![test] # This comment is to test the preprocessor
