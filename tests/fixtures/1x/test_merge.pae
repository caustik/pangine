#
# Test Union Merge
#

['test'] *=  [A]
['test'] *= ![A]

['test'] *=  [A]*[B]
['test'] *= ![A]*![B]

['test'] *=   [A]*[B]
['test'] *= !([A]*[B])

['test'] *= !{[A]->[B]}
['test'] *=  {[A]->[B]}
['test'] *=  {[A]->[B]}
['test'] *= !{[A]->[B]}

['test'] *= !{[A]->[B]} *  {[C]->[D]}
['test'] *=  {[A]->[B]} * !{[C]->[D]}
['test'] *=  {[A]->[B]} *  {[C]->[D]}
['test'] *= !{[A]->[B]}
['test'] *= !{[C]->[D]}

['test'] *=  <50%[A], 50%[B]>
['test'] *= !<50%[A], 50%[B]>

['test'] *= (['test'] *= [A])*[B]
['test'] *= ![B]
['test'] *= ![A]*![A]

['test'] ~= [success]
